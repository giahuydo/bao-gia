# =============================================================================
# n8n Configuration for Bao Gia (Quotation Management)
# =============================================================================
# Copy this file to .env.n8n and update values for your environment.
# NEVER commit .env.n8n with real secrets to version control.
#
# Usage:
#   cp .env.n8n.example .env.n8n
#   # Edit .env.n8n with your values
#   source .env.n8n && docker compose -f docker-compose.n8n.yml up -d
# =============================================================================

# -----------------------------------------------------------------------------
# n8n Database (separate PostgreSQL instance, NOT the Bao Gia database)
# -----------------------------------------------------------------------------

# Database name for n8n's internal storage
N8N_DB_NAME=n8n

# Database user for n8n's PostgreSQL
N8N_DB_USER=n8n

# Database password — CHANGE THIS in production
N8N_DB_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# n8n Admin UI Authentication
# -----------------------------------------------------------------------------

# Username for n8n web UI basic auth
N8N_ADMIN_USER=admin

# Password for n8n web UI basic auth — CHANGE THIS in production
N8N_ADMIN_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# n8n Server Settings
# -----------------------------------------------------------------------------

# Host n8n binds to
N8N_HOST=localhost

# Port n8n listens on (mapped to host) — 5679 to avoid conflict with Clincove n8n (5678)
N8N_PORT=5679

# Protocol: http or https
N8N_PROTOCOL=http

# Timezone for scheduled workflows (IANA format)
N8N_TIMEZONE=America/New_York

# Log level: info, warn, error, debug
N8N_LOG_LEVEL=info

# Log output: console or file
N8N_LOG_OUTPUT=console

# -----------------------------------------------------------------------------
# n8n Webhook Configuration
# -----------------------------------------------------------------------------

# Base URL for n8n webhooks (port 5679 for Bao Gia)
N8N_WEBHOOK_URL=http://localhost:5679

# -----------------------------------------------------------------------------
# n8n API Key (used by Bao Gia server to call n8n REST API)
# -----------------------------------------------------------------------------

# Generate a random key: openssl rand -hex 32
N8N_API_KEY=generate_random_key_here

# -----------------------------------------------------------------------------
# Webhook Secret (used to verify callbacks FROM n8n TO Bao Gia)
# -----------------------------------------------------------------------------

# Both n8n workflows and Bao Gia server must share this secret.
# n8n sends it in the X-Webhook-Secret header; Bao Gia validates it.
# Generate a random key: openssl rand -hex 32
N8N_WEBHOOK_SECRET=generate_random_key_here

# -----------------------------------------------------------------------------
# Execution Data Pruning
# -----------------------------------------------------------------------------

# How long to keep execution data (in hours). 168 = 7 days.
N8N_EXECUTIONS_MAX_AGE=168

# -----------------------------------------------------------------------------
# Bao Gia Server (for n8n to call back into the Bao Gia API)
# -----------------------------------------------------------------------------

# Base URL of the Bao Gia backend API
BAOGIA_API_URL=http://localhost:4001

# Service-to-service key for n8n to authenticate with Bao Gia
# Generate a random key: openssl rand -hex 32
BAOGIA_SERVICE_KEY=generate_random_key_here
